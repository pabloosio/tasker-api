# ===========================
# CONFIGURACIÓN DEL PROYECTO
# ===========================
# 
# IMPORTANTE: Copia este archivo a .env y completa los valores
# El archivo .env NUNCA debe commiterse (está en .gitignore)
#
# Para desarrollo local:
#   cp .env.example .env
#   Edita .env con tus valores locales
#
# ===========================

# ENTORNO
# development | production | test
NODE_ENV=development
PORT=3000

# BASE DE DATOS
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tasker_dev
DB_USER=root
DB_PASSWORD=

# AUTENTICACIÓN (JWT)
# Cambia esto en producción con una clave segura
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRE=7d

# RATE LIMITING
# Poner RATE_LIMIT_ENABLED=false para deshabilitar completamente (recomendado en LAN compartida)
RATE_LIMIT_ENABLED=false
# Ventana de tiempo en minutos
RATE_LIMIT_WINDOW=60
# Máximo requests por ventana por IP
RATE_LIMIT_MAX=50000

# CORS
# Para desarrollo: http://localhost:3000 o * 
# Para producción: especifica tu dominio
CORS_ORIGIN=*

# LOGGING
# error | warn | info | debug
LOG_LEVEL=info

# AWS SES (Para envío de emails)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SES_REGION=us-east-1
SES_FROM_EMAIL=noreply@tasker.com

# FRONTEND URL (Para links en emails)
FRONTEND_URL=http://localhost:5173

# Email Tokens Expiry (en horas)
EMAIL_TOKEN_EXPIRY=24
PASSWORD_RESET_TOKEN_EXPIRY=1





